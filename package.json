{
  "name": "recohub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-schema.js",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:migrate": "wrangler d1 execute recohub-db --remote --file=db/migrate.sql",
    "db:migrate:local": "wrangler d1 execute recohub-db --local --file=db/migrate.sql",
    "db:seed": "wrangler d1 execute recohub-db --remote --file=db/seed.sql",
    "db:seed:local": "wrangler d1 execute recohub-db --local --file=db/seed.sql"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "jose": "^6.1.3",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.25",
    "vue-draggable-plus": "^0.6.1",
    "wrangler": "^4.68.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260304.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5",
    "vitest": "^3.2.4"
  }
}
